{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event",
    "summary",
    "comments"
  ],
  "properties": {
    "event": {
      "type": "string",
      "enum": [
        "COMMENT",
        "REQUEST_CHANGES"
      ],
      "description": "Overall GitHub PR review event to submit."
    },
    "summary": {
      "type": "string",
      "description": "Markdown summary for the PR review timeline."
    },
    "comments": {
      "type": "array",
      "description": "High-signal inline review comments anchored to changed lines.",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "line",
          "side",
          "body"
        ],
        "properties": {
          "path": {
            "type": "string",
            "description": "Repository-relative path for the changed file."
          },
          "line": {
            "type": "integer",
            "minimum": 1,
            "description": "Changed line number on the selected side of the PR diff."
          },
          "side": {
            "type": "string",
            "enum": [
              "LEFT",
              "RIGHT"
            ],
            "description": "Diff side for the anchored review comment."
          },
          "body": {
            "type": "string",
            "description": "Markdown inline review comment body."
          }
        }
      }
    }
  }
}
