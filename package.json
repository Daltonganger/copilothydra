{
  "name": "copilothydra",
  "version": "0.3.4",
  "description": "OpenCode plugin: multiple GitHub Copilot accounts",
  "type": "module",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Daltonganger/copilothydra.git"
  },
  "homepage": "https://github.com/Daltonganger/copilothydra#readme",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "assets/branding/copilothydra-logo-512.png"
  ],
  "bin": {
    "copilothydra": "dist/cli.js"
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "cli": "node dist/cli.js",
    "dev": "tsc --watch",
    "test": "npm run build && node --test tests/**/*.test.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "copilot",
    "plugin"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/openai": "^2.0.51",
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@napi-rs/keyring": "^1.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
